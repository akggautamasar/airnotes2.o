# ── Telegram MTProto ──────────────────────────────────────────────────────────
API_ID=your_api_id
API_HASH=your_api_hash

# Bot tokens (comma-separated for multi-bot load balancing)
BOT_TOKENS=bot1_token,bot2_token

# Optional: Pyrogram string sessions for larger file support (>2 GB)
STRING_SESSIONS=

# Telegram channel/group ID where files are stored (negative number for channels)
STORAGE_CHANNEL=-100xxxxxxxxxx

# Message ID of the first file in the channel (used as scan anchor)
DATABASE_BACKUP_MSG_ID=1

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_me_to_something_strong
JWT_SECRET=change_me_to_a_random_64_char_string

# Your Telegram user ID(s) — can upload files via bot DM
TELEGRAM_ADMIN_IDS=123456789

# ── Deployment ────────────────────────────────────────────────────────────────
# Your Render backend URL (used for auto-ping to prevent sleep)
WEBSITE_URL=https://your-app.onrender.com

# Your Vercel frontend URL (used for CORS)
FRONTEND_URL=https://your-app.vercel.app
